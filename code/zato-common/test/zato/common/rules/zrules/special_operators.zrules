# ################################################################################################################################

rule
    01_Special_Regex_Test
docs
    Tests the matches comparator.
    This rule is used to test the regex matching functionality.
when
    doc_id matches 'AAABBB\s\S+' and
    transaction_type is 'purchase'
then
    result = 'matched_regex'
    action = 'process'

# ################################################################################################################################

rule
    02_Special_Between_Test
docs
    Tests the is between comparator with two inclusive boundaries.
    This rule is used to test range checks.
when
    transaction_amount is between 100 and 1000 and
    transaction_type is 'purchase'
then
    result = 'matched_between'
    action = 'notify'

# ################################################################################################################################

rule
    03_Special_Collection_Membership_Test
docs
    Tests collection membership with the is one of comparator.
    This rule is used to test checking if a value is in a predefined list.
defaults
    allowed_types = ['power_plant', 'water_treatment', 'government', 'hospital']
when
    critical_infrastructure_involved is one of default.allowed_types and
    incident_severity is at least 5
then
    priority_level = 'high'
    response_units = ['fire', 'hazmat']
    notification_level = 'emergency_broadcast'

# ################################################################################################################################

rule
    04_Special_Boolean_Test
docs
    Tests the is true and is false comparators.
    This rule is used to test boolean checks without explicit literals.
when
    premium_services_enrolled is true and
    account_suspended is false and
    amount is more than 1000
then
    priority = 'high'
    notify_manager = true
    special_handling = true

# ################################################################################################################################
