# ################################################################################################################################

rule
    ABC_BANK_001
when
    x is less than max_x and
    amount is more than min_amount and
    income_ratio is more than 0.4
then
    addition = 2.5
    extra_requirements = true
    max_term_years = 3

# ################################################################################################################################

rule
    TELCO_002
docs
    This is a docstring
defaults
    a = 123
    b = 456
    min_transaction_amount = 5000
when
    transaction_type is not customer_type and
    transaction_amount is more than default.min_transaction_amount and
    transaction_category is one of 'fixed', 'variable' and
    title is 'QBC' and
    doc_id matches 'AAABBB\s\S+' and
    abc is d'2025-01-01T00:00:00' and
    hello is 123 # This is a comment too
then
    score = 85
    block_transaction = true
    notification_channel = 'email', 'app_alert'
    outbound_channel = 'sms', channel

# ################################################################################################################################

rule
    Payments_003
docs
    This is a docstring
    it can be multiline
when
    account_balance_average is more than 500000 and
    customer_segment is 'private_banking' and
    relationship_tenure_years is more than 2
then
    fee_waiver = true
    dedicated_advisor = true
    status = {'key1': 'value1', 'key2': 'value2'}

# ################################################################################################################################

rule
    Routing_004
docs
    Routes work automatically unless it arrives through a channel that needs a person.
when
    channel is not one of 'fax', 'pager' or
    priority is at least 8
then
    routing = 'automated'
    handler = channel
else
    routing = 'manual'
    review_queue = 'operations'

# ################################################################################################################################
